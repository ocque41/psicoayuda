{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ayudamental-venezuela",
  "main": "custom-worker.ts",
  "workers_dev": false,
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "saludmental-venezuela.com", "custom_domain": true },
    { "pattern": "www.saludmental-venezuela.com", "custom_domain": true }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "BETTER_AUTH_URL": "https://saludmental-venezuela.com",
    "NEXT_PUBLIC_SITE_URL": "https://saludmental-venezuela.com",
    "GOOGLE_SITE_VERIFICATION": "",
    "NIDO_DB_TARGET": "cloudflare"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nido-venezuela-db",
      "database_id": "b91d3879-2106-4f34-a49c-f8377adb149e",
      "migrations_dir": "drizzle"
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "Conversation", "class_name": "Conversation" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Conversation"] }],
  "triggers": {
    // Retención diaria (03:00 UTC): cierra solicitudes inactivas a 30 días y
    // anonimiza a 90 días (ver custom-worker.ts `scheduled()`).
    "crons": ["0 3 * * *"]
  }
}
