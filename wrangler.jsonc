{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nido-venezuela",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "BETTER_AUTH_URL": "https://nido-venezuela.workers.dev",
    "NIDO_DB_TARGET": "cloudflare"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nido-venezuela-db",
      "database_id": "b91d3879-2106-4f34-a49c-f8377adb149e",
      "migrations_dir": "drizzle"
    }
  ]
}
