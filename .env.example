BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Secreto del RPC interno DO->Next (notificaciones de chat) y del cron de
# retención. Si está vacío cae a BETTER_AUTH_SECRET. En producción conviene uno
# dedicado: `wrangler secret put INTERNAL_NOTIFY_SECRET`.
INTERNAL_NOTIFY_SECRET=
# URL canónica pública del sitio (sin barra final). Se usa para metadatos SEO,
# sitemap.xml, robots.txt, canonical y datos estructurados. En producción debe
# ser el dominio real (idealmente un dominio propio, no *.workers.dev).
NEXT_PUBLIC_SITE_URL=https://nido-venezuela.workers.dev
# Token de verificación de Google Search Console (método "etiqueta HTML").
# Pega solo el valor del atributo content. Vacío = no se emite la meta.
GOOGLE_SITE_VERIFICATION=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=
DATABASE_URL=file:./local.db
ABUSE_CONTACT_EMAIL=
PRIVACY_CONTACT_EMAIL=
NIDO_DB_TARGET=

# Optional Cloudflare D1 deployment notes/config values.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Optional notifications. Email is sent from the Cloudflare Worker via Resend
# (https://resend.com). If RESEND_API_KEY or CONTACT_FROM_EMAIL are empty, email
# is silently skipped. CONTACT_FROM_EMAIL must be a verified Resend sender, e.g.
# "Nido <avisos@tudominio.com>". The professional gets notified at their
# registration email when someone writes to them.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
NOTIFICATION_EMAIL=
