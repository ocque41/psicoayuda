{
  "name": "psicoayuda",
  "version": "0.1.0",
  "description": "Spanish-first connector app for help requests and verified volunteer psychology professionals.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ocque41/psicoayuda.git"
  },
  "bugs": {
    "url": "https://github.com/ocque41/psicoayuda/issues"
  },
  "homepage": "https://github.com/ocque41/psicoayuda#readme",
  "keywords": [
    "venezuela",
    "mental-health",
    "volunteer",
    "nextjs",
    "sqlite",
    "better-auth",
    "drizzle"
  ],
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "build:cloudflare": "PSICOAYUDA_DB_TARGET=cloudflare opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "PSICOAYUDA_DB_TARGET=cloudflare opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "biome check",
    "secret:scan": "node scripts/secret-scan.mjs",
    "format": "biome format --write",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@opennextjs/cloudflare": "^1.20.1",
    "@radix-ui/react-slot": "1.2.4",
    "better-auth": "1.6.22",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.44.7",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "3.4.0",
    "wrangler": "^4.105.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@cloudflare/workers-types": "^4.20260627.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
